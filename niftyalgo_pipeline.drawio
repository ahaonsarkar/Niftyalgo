    <mxCell id="64" value="STEP 1&#xa;Nonconformity Scores&#xa;──────────────────&#xa;Run ensemble on CALIB SET&#xa;→ get predict_proba()&#xa;&#xa;score_i = 1 − P(true_label_i)&#xa;High score = uncertain&#xa;Low score = confident" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b2dfdb;strokeColor=#00695c;fontSize=12;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="80" y="1590" width="310" height="175" as="geometry"/></mxCell>
    <mxCell id="65" value="STEP 2&#xa;Compute  q̂ (threshold)&#xa;──────────────────&#xa;Sort calibration scores&#xa;α = 0.10 (90% coverage)&#xa;&#xa;q̂ = quantile(scores,&#xa;  ⌈(n+1)(1−α)⌉/n)&#xa;(finite-sample corrected)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b2dfdb;strokeColor=#00695c;fontSize=12;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="450" y="1590" width="310" height="175" as="geometry"/></mxCell>
    <mxCell id="66" value="STEP 3&#xa;Generate Prediction Sets&#xa;──────────────────&#xa;For each test week:&#xa;Include label if&#xa;P(label) ≥ (1 − q̂)&#xa;&#xa;{UP}      → clear signal&#xa;{DOWN}    → clear signal&#xa;{UP,DOWN} → uncertain week&#xa;{}        → skip this week" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b2dfdb;strokeColor=#00695c;fontSize=12;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="820" y="1590" width="330" height="175" as="geometry"/></mxCell>
    <mxCell id="67" value="" style="rounded=0;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2;" edge="1" source="64" target="65" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="68" value="" style="rounded=0;orthogonalLoop=1;jettySize=auto;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2;" edge="1" source="65" target="66" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="69" value="" style="rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2;" edge="1" source="40" target="64" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="70" value="" style="rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2;" edge="1" source="41" target="66" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="71" value="METHOD 1&#xa;Baseline Split CP&#xa;──────────────────&#xa;Standard nonconformity score&#xa;One global q̂ threshold&#xa;Simplest implementation&#xa;3 lines of code&#xa;&#xa;Expected width: ±1150 pts&#xa;⚠ Too wide" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f7fa;strokeColor=#0097a7;fontSize=12;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="80" y="1800" width="280" height="155" as="geometry"/></mxCell>
    <mxCell id="72" value="METHOD 2&#xa;CQR  (MAPIE)&#xa;──────────────────&#xa;Conformalized Quantile&#xa;Regression&#xa;Asymmetric intervals&#xa;Separate upper/lower bounds&#xa;&#xa;Expected width: ±550 pts&#xa;✅ Acceptable" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#388e3c;fontSize=12;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="400" y="1800" width="280" height="155" as="geometry"/></mxCell>
    <mxCell id="73" value="METHOD 3&#xa;Normalised CP (VIX)&#xa;──────────────────&#xa;norm_score = score / VIX&#xa;Divide by India VIX weekly&#xa;Calm weeks → narrow intervals&#xa;Volatile weeks → wider&#xa;&#xa;Expected width: ±450 pts&#xa;✅ Good" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#f57f17;fontSize=12;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="720" y="1800" width="280" height="155" as="geometry"/></mxCell>
    <mxCell id="74" value="METHOD 4&#xa;Adaptive ACI / PID-CP&#xa;──────────────────&#xa;Recalibrates α every week&#xa;Online: learns from coverage&#xa;α_t+1 = α_t + γ·error&#xa;PID control variant available&#xa;&#xa;Expected width: Adaptive&#xa;⭐ Best / Most Novel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eaf6;strokeColor=#3949ab;fontSize=12;fontStyle=1;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="1040" y="1800" width="280" height="155" as="geometry"/></mxCell>
    <mxCell id="75" value="" style="rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2;" edge="1" source="66" target="71" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="76" value="" style="rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2;" edge="1" source="66" target="72" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="77" value="" style="rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2;" edge="1" source="66" target="73" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="78" value="" style="rounded=0;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#555555;strokeWidth=2;" edge="1" source="66" target="74" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell>
    <mxCell id="79" value="H  EVALUATION METRICS (per CP method)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#880e4f;fontSize=13;fontStyle=1;verticalAlign=top;align=left;opacity=40;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="50" y="2005" width="1700" height="170" as="geometry"/></mxCell>
    <mxCell id="80" value="Coverage&#xa;──────────&#xa;% true labels inside&#xa;prediction set&#xa;Target: ≥ 90%&#xa;(must never fail)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#880e4f;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="80" y="2035" width="220" height="120" as="geometry"/></mxCell>
    <mxCell id="81" value="Avg Set Size&#xa;──────────&#xa;1.0 = certain&#xa;2.0 = uncertain&#xa;0.0 = anomalous&#xa;Target: close to 1.0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#880e4f;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="340" y="2035" width="220" height="120" as="geometry"/></mxCell>
    <mxCell id="82" value="Singleton Rate&#xa;──────────&#xa;% of weeks with&#xa;clean single prediction&#xa;Higher = better&#xa;actionable signal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#880e4f;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="600" y="2035" width="220" height="120" as="geometry"/></mxCell>
    <mxCell id="83" value="Empty Set Rate&#xa;──────────&#xa;% of weeks model&#xa;says 'skip'&#xa;Non-zero = model&#xa;knows its limits" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#880e4f;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="860" y="2035" width="220" height="120" as="geometry"/></mxCell>
    <mxCell id="84" value="Event Coverage&#xa;──────────&#xa;Coverage during&#xa;RBI / Budget weeks&#xa;vs normal weeks&#xa;Degradation check" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#880e4f;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="1120" y="2035" width="220" height="120" as="geometry"/></mxCell>
    <mxCell id="85" value="Conditional Coverage&#xa;──────────&#xa;Coverage for&#xa;UP weeks separately&#xa;DOWN weeks separately&#xa;Balance check" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce4ec;strokeColor=#880e4f;fontSize=11;fontStyle=0;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="1380" y="2035" width="220" height="120" as="geometry"/></mxCell>
